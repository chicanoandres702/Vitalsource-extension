{
  "manifest_version": 3,
  "name": "VitalSource Pilot Pro",
  "version": "10.0.0",
  "description": "Autonomous book scraping engine for VitalSource.",
  "permissions": [
    "sidePanel",
    "tabs",
    "activeTab",
    "scripting",
    "storage",
    "unlimitedStorage",
    "downloads",
    "webNavigation"
  ],
  "host_permissions": [
    "*://bookshelf.vitalsource.com/*",
    "*://capella.vitalsource.com/*",
    "*://mosaic.vitalsource.com/*",
    "*://jigsaw.vitalsource.com/*",
    "*://*.capella.edu/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open Pilot Pro"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://bookshelf.vitalsource.com/*",
        "*://capella.vitalsource.com/*",
        "*://mosaic.vitalsource.com/*",
        "*://jigsaw.vitalsource.com/*",
        "*://*.capella.edu/*"
      ],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}