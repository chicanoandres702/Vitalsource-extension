{
  "manifest_version": 3,
  "name": "VitalSource Pilot Pro",
  "version": "1.1.0",
  "description": "Professional automation and extraction tool for VitalSource Bookshelf.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "sidePanel"
  ],
  "host_permissions": [
    "https://*.vitalsource.com/*"
  ],
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "action": {
    "default_title": "VitalSource Pilot Pro"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.vitalsource.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/features/platform/detection.service.js",
        "src/features/ripping/storage.service.js",
        "src/features/ripping/watchdog.service.js",
        "src/features/navigation/turner.service.js",
        "src/features/ui/renderer.service.js",
        "src/features/capture/cleaner.feature.js",
        "src/features/capture/stabilizer.feature.js",
        "src/features/dom/scanner.feature.js",
        "src/features/engine/autopilot.feature.js",
        "orchestrator.js",
        "intercept.js",
        "sidebar.html",
        "sidebar.js",
        "print.html",
        "print.js",
        "icon.svg"
      ],
      "matches": [
        "https://*.vitalsource.com/*"
      ]
    }
  ],
  "icons": {
    "128": "icon.svg"
  }
}