{
  "manifest_version": 3,
  "name": "VitalSource Pilot Pro",
  "version": "9.3.0",
  "description": "Autonomous PDF Engine: Removed body fallback, blocked Syncing states, decoupled CSS payloads, and batched PDF rendering.",
  "permissions": ["sidePanel", "tabs", "activeTab", "scripting", "storage", "unlimitedStorage", "management", "debugger", "downloads"],
  "host_permissions": [
    "*://bookshelf.vitalsource.com/*",
    "*://capella.vitalsource.com/*",
    "*://mosaic.vitalsource.com/*",
    "*://jigsaw.vitalsource.com/*",
    "*://*.capella.edu/*"
  ],
  "background": {
    "service_worker": "dist/background.entry.js"
  },
  "action": {
    "default_title": "Open Pilot Pro",
    "default_icon": "icon.svg"
  },
  "icons": {
    "16": "icon.svg",
    "48": "icon.svg",
    "128": "icon.svg"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://bookshelf.vitalsource.com/*",
        "*://capella.vitalsource.com/*",
        "*://mosaic.vitalsource.com/*",
        "*://jigsaw.vitalsource.com/*",
        "*://*.capella.edu/*"
      ],
      "js": ["dist/intercept.entry.js", "dist/content.entry.js"],
      "all_frames": true,
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://bookshelf.vitalsource.com/*",
        "*://capella.vitalsource.com/*",
        "*://mosaic.vitalsource.com/*",
        "*://jigsaw.vitalsource.com/*",
        "*://*.capella.edu/*"
      ],
      "js": ["src/features/mobile/floating-menu.js"],
      "css": ["src/features/mobile/menu.styles.css"],
      "all_frames": false,
      "run_at": "document_idle"
    }
  ]
}
