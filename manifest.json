{
  "manifest_version": 3,
  "name": "VitalSource Pilot Pro",
  "version": "9.3.0",
  "description": "Autonomous PDF Engine: High-fidelity capture via Mimeo API and Mosaic container targeting.",
  "permissions": ["sidePanel", "tabs", "activeTab", "scripting", "storage", "unlimitedStorage", "management", "debugger", "downloads"],
  "host_permissions": [
    "*://bookshelf.vitalsource.com/*",
    "*://capella.vitalsource.com/*",
    "*://mosaic.vitalsource.com/*",
    "*://jigsaw.vitalsource.com/*",
    "*://*.vitalsource.com/*",
    "*://*.capella.edu/*"
  ],
  "background": {
    // Design Intent: Reference the bundled file in the distribution root.
    // This allows the entire 'dist' folder to be loaded as the extension.
    "service_worker": "background.entry.js"
  },
  "action": {
    "default_title": "Open Pilot Pro",
    "default_icon": "icon.svg"
  },
  "icons": {
    "16": "icon.svg",
    "48": "icon.svg",
    "128": "icon.svg"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://bookshelf.vitalsource.com/*",
        "*://capella.vitalsource.com/*",
        "*://mosaic.vitalsource.com/*",
        "*://jigsaw.vitalsource.com/*",
        "*://*.vitalsource.com/*",
        "*://*.capella.edu/*"
      ],
      // Design Intent: dist/content.entry.js contains the MimeoBridge and 
      // UI listeners. Injecting into all_frames is critical for 
      // piercing the mosaic-book content iframes.
      "js": ["intercept.entry.js", "content.entry.js"],
      "all_frames": true,
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://bookshelf.vitalsource.com/*",
        "*://capella.vitalsource.com/*",
        "*://mosaic.vitalsource.com/*",
        "*://jigsaw.vitalsource.com/*",
        "*://*.capella.edu/*"
      ],
      // Design Intent: Reference the processed files now residing in dist
      "js": ["floating-menu.js"],
      "css": ["menu.styles.css"],
      "all_frames": false,
      "run_at": "document_idle"
    }
  ]
}
